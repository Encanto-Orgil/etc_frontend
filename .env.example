# Local development — copy to .env.local
#   cp .env.example .env.local

# Public site URL — canonical links, sitemap, Open Graph
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Django API (local backend)
NEXT_PUBLIC_API_BASE=http://localhost:8000/api

# Video assets (R2 CDN — same as production)
NEXT_PUBLIC_TRADE_VIDEO_URL=https://pub-6c7c4c348453498291848eaef41bf007.r2.dev/trade.mp4
NEXT_PUBLIC_OFFICE_VIDEO_URL=https://pub-6c7c4c348453498291848eaef41bf007.r2.dev/video/ETC-W%201080HD%20copy.mp4
NEXT_PUBLIC_BALLROOM_VIDEO_URL=https://pub-6c7c4c348453498291848eaef41bf007.r2.dev/trade.mp4
NEXT_PUBLIC_MALL_VIDEO_URL=https://pub-6c7c4c348453498291848eaef41bf007.r2.dev/trade.mp4

# Optional: serve homepage gallery from R2 (leave empty to use /public/images)
# Example after uploading images/renders, images/drone, images/mall, images/ballroom to R2:
# NEXT_PUBLIC_GALLERY_CDN_BASE=https://pub-6c7c4c348453498291848eaef41bf007.r2.dev
NEXT_PUBLIC_GALLERY_CDN_BASE=
